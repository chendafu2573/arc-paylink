{
  "name": "arc-paylink",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "contract:compile": "node scripts/compile-contract.mjs",
    "agent-vault:compile": "node scripts/compile-agent-vault.mjs",
    "agent-vault:deploy": "node scripts/deploy-agent-vault.mjs",
    "agent:register": "node scripts/register-agent-identity.mjs",
    "agent:dry-run": "node scripts/run-payment-agent.mjs",
    "agent:execute": "node scripts/run-payment-agent.mjs --execute",
    "agent:erc8183": "node scripts/run-erc8183-job.mjs",
    "agent:gateway": "node scripts/run-gateway-agent.mjs",
    "agent:receipt": "node scripts/generate-agent-receipt.mjs",
    "agent:receipt:check": "node scripts/generate-agent-receipt.mjs --check",
    "agent:receipt:verify": "node scripts/verify-agent-receipt.mjs",
    "agent:receipt:anchor": "node scripts/anchor-agent-receipt.mjs",
    "contract:deploy": "node scripts/deploy-escrow.mjs",
    "contract:verify": "node scripts/verify-escrow.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.2.0",
    "@vitejs/plugin-react": "latest",
    "@x402/core": "^2.18.0",
    "@x402/evm": "^2.18.0",
    "express": "^5.2.1",
    "qrcode": "latest",
    "react": "latest",
    "react-dom": "latest",
    "viem": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/qrcode": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "solc": "^0.8.36",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}
